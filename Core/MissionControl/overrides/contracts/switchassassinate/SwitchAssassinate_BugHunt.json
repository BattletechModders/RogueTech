	"dialogueList": [
		{
			"dialogue": {
				"EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
			},
			"name": "Dialogue_MissionStart",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "This is the place, Commander. Meyer, can you see the target anywhere? We're blind on the ground.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "I've got an engine signature... here. Best I can do, boss.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "f78cce05-8078-4f5d-b240-256af1f7f71b",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": 0
				},
				{
					"words": "The target might make a break for it once you engage, Commander. Be ready to intercept if they run.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "76b654a6-4f2c-4a6f-86e6-d4cf868335fe",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
			"dialogue": {
				"EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
			},
			"name": "Dialogue_MissionSuccess",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>   Commander, you have completed the objective.  Payment will be transferred.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}Funny way to treat your agents.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}Next time, give us the whole truth.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  No promises.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
			"dialogue": {
				"EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
			},
			"name": "Dialogue_MissionFailure",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "We've failed...",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
			"dialogue": {
				"EncounterObjectGuid": "bee9e015-7620-4d0b-86de-20047f5c0d84"
			},
			"name": "Dialogue_Target_Lance_01_Hint",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}Commander, I've got partial comm chatter...encrypted, but it's not {TEAM_TAR.FactionDef.ShortName} standard.\n\r\nHere I'll patch it through.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}<color=#99ebff>Terrorist:</color>  ...if this reaches {TEAM_EMP.FactionDef.ShortName} command, authentication code...returning from cold --- request immediate...",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_Computer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}\"Returning from cold\"?  That's not terrorist talk.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  Commander, abort engagement immediately.  Do not engage the target.\n\r\nThat \"target\" is one of ours --- deep cover operative embedded within hostile territory.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}You're telling me you're hunting your own agent for months?",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  Compartmentalization.  Need-to-know.  Those who ordered the \"hit\" didn't need to know.\n\r\nThis agent's been in the dark for too long.  We believe they're coming in from the cold...DO NOT ENGAGE the target until we verify the credentials.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
			"dialogue": {
				"EncounterObjectGuid": "3d1097b0-5e92-4dd3-8764-901881dc2480"
			},
			"name": "Dialogue_Target_Lance_01_Swap",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{MC.Modification.AddTo.EncounterTags.TeamSwapped}{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  Commander, confirmation received.  The \"terrorist\" is our deep cover agent and is legitimate.  They've been made and are now being hunted by their own side.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "f78cce05-8078-4f5d-b240-256af1f7f71b",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.Modification.AddTo.EncounterTags.TeamSwapped}{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  New orders: protect the agent at all costs.  Link up and escort them to the rally point for evacuation.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "f78cce05-8078-4f5d-b240-256af1f7f71b",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}New orders: <b>protect and escort the target</b>, now our principal, to the evac point.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "ce56f076-15a6-490b-a73f-71316b1566c4",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.Modification.AddTo.EncounterTags.TeamSwapped}{MC.If.Encounter.HasNoTag.KilledAllOpfor}All units, change of mission.  We're not hunting anymore --- we're shielding.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_Commander",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "f78cce05-8078-4f5d-b240-256af1f7f71b",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
