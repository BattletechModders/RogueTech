			},
			"name": "Dialogue_KillAllOpfor",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{MC.Modification.AddTo.EncounterTags.KilledAllOpfor}<color=#99ebff>{TEAM_EMP.FactionDef.Government} Intel Liason Officer:</color>  Commander, we're seeing zero enemy signatures.\n\r\nWith enemy forces eliminated, extraction can proceed at your discretion.  Rally point is no longer contested.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
