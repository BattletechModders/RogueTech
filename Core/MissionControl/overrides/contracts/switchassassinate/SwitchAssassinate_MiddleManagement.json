	"dialogueList": [
		{
			"dialogue": {
				"EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
			},
			"name": "Dialogue_MissionStart",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "Commander, our intel was right; the target is in the AO and only lightly guarded.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "We're seeing a lot of {TEAM_TAR.FactionDef.Demonym} activity nearby.  That's probably our target.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "f78cce05-8078-4f5d-b240-256af1f7f71b",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": 0
				},
				{
					"words": "Take them out, get to the evac zone, and then we get paid.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "76b654a6-4f2c-4a6f-86e6-d4cf868335fe",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
			"dialogue": {
				"EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
			},
			"name": "Dialogue_MissionSuccess",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>Target/Principal:</color>  Took you long enough, mercenaries!",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}You could've warned us.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{MC.If.Encounter.HasNoTag.KilledAllOpfor}<color=#99ebff>Target/Principal:</color>  If I had, I'd already be dead.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamLeader_Employer",
					"emote": "Default",
					"audioName": "NONE",
