		{
			"dialogue": {
				"EncounterObjectGuid": "bee9e015-7620-4d0b-86de-20047f5c0d84"
			},
			"name": "Dialogue_Target_Lance_01_Hint",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}Darius, the target's movement is \"off\".  IFF also does not match a hostile blip.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}Stand by --- receiving conflicting data. {TEAM_EMP.FactionDef.Demonym}'s says a possible mis-ID.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}We're in range.  Engage or hold?",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}Verifying the target with our employer.\n\r\nHold fire.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "{{MC.If.Encounter.HasNoTag.TeamSwapped} AND {MC.If.Encounter.HasNoTag.KilledAllOpfor}}Roger, hope it gets sorted soon...",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Random_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
