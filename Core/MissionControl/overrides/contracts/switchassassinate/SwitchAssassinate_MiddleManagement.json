			},
			"name": "Dialogue_Target_Lance_01_Swap",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "{MC.Modification.AddTo.EncounterTags.TeamSwapped}{MC.If.Encounter.HasNoTag.KilledAllOpfor}Commander, abort!\n\r\nTarget is a deep-cover agent inside {TEAM_TAR.FactionDef.Demonym}.",
