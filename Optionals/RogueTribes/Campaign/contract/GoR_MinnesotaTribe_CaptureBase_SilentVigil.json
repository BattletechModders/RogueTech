  "dialogueList": [
    {
      "dialogue": {
        "EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
      },
      "name": "Dialogue_MissionStart",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Tactical scan confirms heavy defensive presence around the facility. Advanced turret network, multiple contacts on sensors. This installation is very well protected.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "181efcdf-0e34-477b-8a06-39b0ead2d69e",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "The garrison strength matches what Joanna's intel predicted for a high-value Watch installation. Standard approach applies here. Break the perimeter defenses, push through to the objective.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "I'm queuing electronic warfare packages to deploy once we breach the facility perimeter. We need to prevent remote data purge protocols from activating.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Those turrets and that garrison are no joke. This is going to be a real fight to crack this place open.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Engage the defenses and push through to the objective. Move in.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_Commander",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
      },
      "name": "Dialogue_MissionSuccess",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We just stormed a refugee camp. Families, full of children. We destroyed critical facilities for displaced civilians.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Get us out of here. Now.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "I'm archiving all sensor data and facility scans, all available information from this mission. We must find out what went wrong, why our own intel was so wrong.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
      },
      "name": "Dialogue_MissionFailure",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We couldn't break through the garrison. Pull back now before we lose more people fighting for this.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "692713e2-ddc8-4e4e-963b-81163f2fc598"
      },
      "name": "Dialogue_EnemiesSpotted",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Contact confirmed. Defenders are fielding frontline Watch combat units. Professional deployment, coordinated defensive positions.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "That tracks with a priority Watch installation. They're committing quality forces to protect whatever intelligence is inside. Push forward into the defensive perimeter.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "9071057f-44c7-44ee-a23e-10bc7bab3e00"
      },
      "name": "Dialogue_GoToComplete_EnemiesRemain",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "The camp is under our control, but the defenders are still actively engaging us.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "That leaves us no other choice but to deal with them, they are ignoring all attempts to communicate.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "774f075d-acb4-43d0-aeb2-607292ecd3db"
      },
      "name": "Dialogue_EnemiesComplete_GoToRemain",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "That's all the defenders down. We just need to take control of the outpost.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d61f12a3-f820-4026-b7ca-9d263d1525fa"
      },
      "name": "Dialogue_Interrupt_DropshipLanding",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Dropship is arriving, let's leave while we can.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "9193a080-418b-4e46-aeb0-f8ac55fb63b5"
      },
      "name": "Dialogue_Interrupt_TurretWarning",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Turrets are activating! The turret network is extensive and extremely well maintained. This defensive grid was designed by professionals who knew exactly what they were doing.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "9a1bfa77-fc82-4e20-be61-63ebe1d1949e",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Whoever set this place up was expecting to get hit hard. They built this to withstand a serious assault. We're committed now.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "9a1bfa77-fc82-4e20-be61-63ebe1d1949e",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "37173dfd-65d9-40dc-b498-906086595931"
      },
      "name": "Dialogue_Interrupt_GoToComplete",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We're approaching the objective. Sensors are getting clear readings past the military perimeter now. Wait. Commander, the inner structures don't match intelligence infrastructure at all.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "That's odd, I'm reading only civilian facilities. A medical clinic, temporary shelter units, educational facilities, basic warehouses. This layout is completely wrong for a surveillance post.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Oh no, it can't be! This is a civilian refugee processing center! The Ghost Bears weren't protecting intelligence operations. They were protecting the retreat of their families.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Damn! After months of Tribe attacks on Ghost Bear targets, of course they'd fortify their civilian centers with frontline troops. The military garrison wasn't proof this was important intelligence, it was proof the Ghost Bears are terrified for their people.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "It's another damned lie from Joanna. This will be the last one, ever. I will make sure of that personally!",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_Commander",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Commander, the Ghost Bears refuse all communications! We can't tell them it's a mistake!",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Blast! That means there is no option for us to withdraw, they will hit us in our backs. We will have to fight this out...",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "So we will have to harm even more civilians. May the afterlife have mercy on our souls.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "a85da736-7a2e-4cc6-aff3-feb9d73fc7e1",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    }
