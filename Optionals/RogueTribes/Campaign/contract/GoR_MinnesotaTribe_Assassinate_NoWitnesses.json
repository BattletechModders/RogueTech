  "dialogueList": [
    {
      "dialogue": {
        "EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
      },
      "name": "Dialogue_MissionStart",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target confirmed nearby. Advanced mech with escort lance. They're moving toward what seems to be an emergency evacuation location.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "This is pursuit and elimination. Target knows the terrain and has a head start. We need to intercept before he reaches the evac point.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Detecting nearby civilian structures with a considerable amount of active heat signals. Let's try to avoid unnecessary civilian damage.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Target's in an advanced mech. Good armor, good weapons. Escorts are providing security but he's the priority. Drop him and the mission's done.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Confirmed, target priority is Jorgensson. Eliminate him before he reaches evac. Move in.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_Commander",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
      },
      "name": "Dialogue_MissionSuccess",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target eliminated. Jorgensson's dead. Mission accomplished.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Whatever intel Jorgensson had on Tribe operations, it died with him. Joanna's network stays secure.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Collateral damage assessment shows some structural damage to civilian buildings. Most of them still seem sound enough to remain standing.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Not much to be done about that, just an unlucky location for an engagement.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
      },
      "name": "Dialogue_MissionFailure",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target escaped. Jorgensson made it to the evac point. He's off planet with everything he knows about Tribe operations.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "That intelligence is going straight to Ghost Bear Watch command. Joanna's network is compromised. This is bad.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "dafa63cd-96e8-4a03-8383-6abfd360bde8"
      },
      "name": "Dialogue_Interrupt_KillConfirmedEscapeInstruction",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target down! Jorgensson's mech is destroyed. Confirm pilot KIA.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Confirmed. Target eliminated. Primary objective complete. We can withdraw now or mop up remaining hostiles.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
