      "name": "Dialogue_TargetDamaged",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target's taking damage! Jorgensson's armor is compromised. Keep the pressure on!",
          "wordsColor": {
            "r": 1,
