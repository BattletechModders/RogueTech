  "dialogueList": [
    {
      "dialogue": {
        "EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
      },
      "name": "Dialog_MissionStart",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "The production facility is straight ahead. Multiple heavy contacts detected, one is exceptionally large. That has to be the Armageddon prototype.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Joanna's deployed everything she has left. The prototype, her best warriors, everything. They're not running. They're making their stand here.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Engage all targets. Destroy the prototype, eliminate Joanna McEvedy, demolish the facility. Final assault begins now.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
      },
      "name": "Dialog_MissionSuccess",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "That's it. The facility is destroyed and the prototype ruined. All hostile forces down.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "All that remains is to find Joanna, but I am not detecting her biosignal. Maybe she is still inside the smoking mountain that is the remains of the Armageddon?",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
      },
      "name": "Dialog_MissionFailure",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We couldn't do it. Too much damage, too many hostiles. Fall back if we can.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "I am sorry everyone. I have no choice but to detonate the warhead... At least it is a noble death for a good cause.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_MarcusHammerick",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Much good that will do us in our grave! If we even get one.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
