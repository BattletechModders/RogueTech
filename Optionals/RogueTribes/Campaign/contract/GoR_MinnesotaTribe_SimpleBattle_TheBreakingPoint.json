  "dialogueList": [
    {
      "dialogue": {
        "EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
      },
      "name": "Dialogue_MissionStart",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Perimeter defenders' sensor signals confirmed. Multiple contacts holding defensive positions. They're dug in and waiting for us.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "These are true believers. They think they're protecting their people's survival. They won't break. They won't retreat. We go through them or we don't go at all.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Environmental conditions are worse than projected. Visibility is terrible, sensor interference is constant. This frozen hellscape works against everyone equally.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "They're ready to die here. I am not. Let's make sure they get what they're expecting, no survivors.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
      },
      "name": "Dialogue_MissionSuccess",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Perimeter defenders eliminated. All contacts down. The outer defenses are breached.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Phase Two begins immediately, no time for repairs or rest. The production facility is ahead and Joanna knows we're coming.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_Commander",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "We're already damaged and we're going straight into the next fight. This is going to be brutal.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_YangDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Move to the inner facility now. Joanna will deploy everything she has left. The Armageddon prototype is waiting.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_MarcusHammerick",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
      },
      "name": "Dialogue_MissionFailure",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We couldn't break through. Perimeter defenders are still operational. We're taking too much damage to continue.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Everyone back to the Argo as fast as we can, ignore any permanent damage to the Leopard. Now we have to outrun a nuclear blast of unimaginable proportions...",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_Commander",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "33166b96-5af2-4724-b970-7884ec41ffd0"
      },
      "name": "Dialogue_AmbushWarning",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Careful, enemy signals detected in rapid close-range approach!",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    }
  ],
