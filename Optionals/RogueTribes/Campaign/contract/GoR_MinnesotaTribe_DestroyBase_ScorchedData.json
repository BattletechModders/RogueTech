  "dialogueList": [
    {
      "dialogue": {
        "EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
      },
      "name": "Dialog_MissionStart",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Target facility detected. Sensors show standard defensive layout. Two garrison mechs on patrol, automated turrets at cardinal points. No heavy reinforcements in range yet.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "This is a demolition run. We hit the data core, wreck the backup generators, and torch anything that looks like a filing cabinet. Fast in, fast out, before they scramble a response.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Infrastructure analysis suggests civilian-grade construction. Data storage will be centralized, likely in the main complex. Destroying primary servers and power distribution should render everything unrecoverable.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Garrison's running lighter mechs. Nothing that'll give us trouble if we keep the pressure on. Focus your fire on structural supports once we're inside the perimeter.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "f22d699f-edce-4f14-b520-8580535f620f",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Primary target is the data vault. Everything else is collateral. Burn it all. Move in.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_JoannaMcEvedy",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "4011a4c3-cba2-4d22-b2b3-3b19a3297ab9"
      },
      "name": "Dialog_MissionSuccess",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Data core is slag. Backup systems are offline. Whatever records they had, they're not getting them back. Not from here.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "No further transmission detected either, now it is all silent except for the fires and explosions.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Facility is compromised beyond recovery. Mission complete. Time to get clear before they send investigators.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_FarahDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "d3d33d95-9ed7-4686-b9eb-954ebe51cc02"
      },
      "name": "Dialog_MissionFailure",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "We're pulling back. Target's still operational and reinforcements are moving in. The data survived this run.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "5e45a01d-01a2-40bf-b4ce-c963eb32f26d"
      },
      "name": "Dialogue_Interrupt_AmbushWarning",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Commander, incoming heavy reinforcements detected on long range sensors!",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "a2472c65-4ab9-4c45-a5d3-e51a151ae25e"
      },
      "name": "Dialogue_EscapeDirection",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "It's all a burning inferno, let's get out of here.",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "719d08e9-5bf9-4dc0-a13b-ad86bac4a65d"
      },
      "name": "Dialogue_TargetBuildingDamaged",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "<i>*static*</i>-repeat, to all enemy forces. This is a civ-<i>*static*/<i>-allow for evacuation-<i>*static*/<i>",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_MC_CommsOfficer",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Did anyone copy that transmission? Something about evacuation?",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_SumireDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "I am not sure. Maybe worth investigat..-",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_DariusDefault",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        },
        {
          "words": "Negative! It is just a false attempt to trick you until reinforcements arrive. Press on!",
          "wordsColor": {
            "r": 1,
            "g": 1,
            "b": 1,
            "a": 1
          },
          "selectedCastDefId": "castDef_JoannaMcEvedy",
          "emote": "Default",
          "audioName": "NONE",
          "cameraFocusGuid": "",
          "cameraDistance": "Far",
          "cameraHeight": "Default",
          "revealRadius": -1
        }
      ]
    },
    {
      "dialogue": {
        "EncounterObjectGuid": "e882f006-f7fd-4048-9c29-56553a5b5698"
      },
      "name": "Dialogue_TargetBuildingDestroyed",
      "overrideDialogueBucketId": "",
      "dialogueContent": [
        {
          "words": "Commander, that is one building down. Let's destroy the rest and get out of here.",
          "wordsColor": {
            "r": 1,
