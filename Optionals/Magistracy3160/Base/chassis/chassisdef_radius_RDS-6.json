    "Id": "chassisdef_radius_RDS-6",
    "Name": "Radius",
    "Details": "The Radius RDS-6 is an 85-ton Word of Blake assault platform built around a C3 Master Computer occupying the entire left torso, designed to coordinate networked lance members rather than win battles through raw firepower. Three arm-mounted Light PPCs provide reliable energy-based support fire, while a right-arm MRM 40 paired with an Apollo Fire Control System delivers punishing close-range volleys. Six Improved Jump Jets grant unexpected battlefield mobility for a machine of this size.\n\n<b><color=#e62e00>Quirk: Command Mech</color></b>\n\n<b><color=#e62e00>Drop Cost Multiplier: 1.15</color></b>",
    "Icon": "uixTxrIcon_radius"
  },
  "VariantName": "RDS-6",
  "ChassisTags": {
    "items": [
      "mr-resize-0.93-1.09-0.91"
    ],
    "tagSetSourceFile": ""
